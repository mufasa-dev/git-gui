{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trident",
  "version": "0.1.0",
  "identifier": "com.git-trident.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Git Trident",
        "width": 800,
        "height": 600,
        "resizable": true,
        "maximized": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "assets/karma-bridge.conf.cjs", 
      "assets/karma-bridge-legacy.conf.js"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": {
          "pt-BR": {
            "localePath": "assets/pt-br.wxl"
          }
        },
        "bannerPath": "assets/banner.bmp",
        "dialogImagePath": "assets/side.bmp"
      },
      "nsis": {
        "languages": ["PortugueseBR", "English"],
        "installerIcon": "icons/icon.ico",
        "headerImage": "assets/banner_nsi.bmp",
        "sidebarImage": "assets/side_nsi.bmp",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "protocols": [
        {
          "scheme": "git-trident",
          "role": "viewer"
        }
      ]
    },
    "shell": {
      "open": true
    }
  }
}
