{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    "store:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "os:default",
    "http:default",
    "http:allow-fetch-send",
    {
      "identifier": "http:allow-fetch-send",
      "allow": [{ "url": "https://*.gravatar.com/*" }]
    },
    "http:allow-fetch",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://*.gravatar.com/*" }]
    }
  ]
}